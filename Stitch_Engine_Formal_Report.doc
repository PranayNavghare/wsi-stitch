<head>
<meta charset="utf-8">
<style>
body{font-family:Calibri,Arial,sans-serif;font-size:11pt;line-height:1.38;color:#222;margin:36pt;}
h1{font-size:24pt;text-align:center;margin-bottom:4pt;}
h2{font-size:16pt;margin-top:18pt;margin-bottom:8pt;color:#1f4e79;border-bottom:1px solid #b8cce4;padding-bottom:3pt;}
h3{font-size:13pt;margin-top:14pt;margin-bottom:6pt;color:#1f4e79;}
p{margin:6pt 0;} ul{margin-top:4pt;margin-bottom:8pt;} li{margin-bottom:3pt;}
table{border-collapse:collapse;width:100%;margin:8pt 0 12pt 0;} th,td{border:1px solid #999;padding:5pt;vertical-align:top;} th{background:#d9eaf7;font-weight:bold;}
pre{background:#f4f4f4;border:1px solid #ddd;padding:8pt;font-family:Consolas,monospace;font-size:9pt;white-space:pre-wrap;}
